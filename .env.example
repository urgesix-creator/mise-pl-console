# ====================================================================
# 環境変数テンプレート
# 実際の値は .env.local にコピーして設定してください
# .env.local は .gitignore で無視されます
# ====================================================================

# ====================================================================
# Supabase（必須）
# ====================================================================

# Supabase プロジェクト URL
# 取得：Supabase Dashboard > Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Supabase Anonymous Key（公開可、ブラウザで使用）
# 取得：Supabase Dashboard > Settings > API > Project API keys > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Supabase Service Role Key（機微、Server-side のみ使用）
# 取得：Supabase Dashboard > Settings > API > Project API keys > service_role
# 注意：絶対に NEXT_PUBLIC_ プレフィックスを付けないこと
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# サイトURL（必須）：パスワード再設定メール・ユーザー招待メールのリンク先に使用
# ローカル：http://localhost:3000
# 本番：Vercel のデプロイURL（例 https://sales-console.vercel.app）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ====================================================================
# Slack（任意、配信時に必要）
# ====================================================================

# Incoming Webhook URL
# 取得：Slack App ダッシュボード > Incoming Webhooks
# 注：system_settings.slack_webhook_url にDB保存も可（経営層が画面から変更可能にする場合）
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T0XXXXXXX/B0XXXXXXX/YYYYYYYYYY

# ====================================================================
# その他（任意）
# ====================================================================

# Vercel Analytics（任意）
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# Sentry エラー監視（任意、Phase 2以降）
# NEXT_PUBLIC_SENTRY_DSN=
